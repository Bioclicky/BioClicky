<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farmácias | BioClicky</title>
    <link rel="stylesheet" href="/css/home.css">
</head>
<body>

<!-- ===================================== HEADER ===================================== -->

<header class="cabecalho">
    <a href="/" class="logo">
        <img src="/imagens/logo-header/logo-e-titulo.png" alt="BioClicky">
    </a>
    <nav class="menu-container">
        <span class="indicador"></span>
        <ul class="menu">
            <li><a href="/">Início</a></li>
            <li><a href="/remedios">Remédios</a></li>
            <li><a href="/farmacias" class="ativo">Farmácias</a></li>
            <li><a href="/categorias">Categorias</a></li>
            <li><a href="/sobre">Sobre</a></li>
        </ul>
    </nav>
    <% if(logado){ %>
    <button class="perfil-btn">
        <ion-icon name="person-outline"></ion-icon>
    </button>
    <% }else{ %>
    <button
        class="entrar"
        onclick="window.location.href='/login'"
    >
        <ion-icon name="person-outline"></ion-icon>
        Entrar
    </button>
    <% } %>
</header>

<!-- ===================================== CONTEÚDO ===================================== -->

<main class="farmacias-container">
<header class="farmacias-titulo">
    <h1>Farmácias Parceiras</h1>
    <p>
        Encontre farmácias parceiras da BioClicky próximas de você.
    </p>
</header>
<form class="farmacias-pesquisa">
    <ion-icon
        name="search-outline"
    ></ion-icon>
    <input
        type="text"
        placeholder="Pesquisar farmácia..."
    >
</form>
<section class="farmacias-grid">

<!-- =====================================  ===================================== -->

<article class="farmacia-card">
    <figure class="farmacia-icone">
        <ion-icon name="business-outline"></ion-icon>
    </figure>
    <section class="farmacia-info">
        <header class="farmacia-topo">
            <h2>Droga Raia</h2>
            <span class="verificado">
                <ion-icon name="checkmark-circle"></ion-icon>
            </span>
        </header>
        <p class="nota">
            <ion-icon name="star"></ion-icon>
            4.3
        </p>
        <p>
            <ion-icon name="location-outline"></ion-icon>
            Rua Augusta, 2200 • São Paulo
        </p>
        <p>
            <ion-icon name="call-outline"></ion-icon>
            (11) 3120-5500
        </p>
        <small class="selo">
            Parceira BioClicky
        </small>
    </section>
</article>

